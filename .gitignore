## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Status: Microsoft's recommended .gitignore for Visual Studio

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.ReSharper.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Entity Framework 6 (Note: Standard name is 'migrate.exe')
migrate.exe

# Microsoft Azure Build Output
csx/
*.build.csdef

# Azure Functions local settings file
local.settings.json

# Visual Studio Previews
AppPackages/
BundleArtifacts/

# JSON settings
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCop.Cache

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Compiled results
*.dll
*.exe
*.pdb
*.lib
*.nativecodeanalysis.all.xml
*.nativecodeanalysis.xml

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Other
*.bak
*.cache
*.log
*.tmp
.DS_Store
